<ui:FluentWindow x:Class="PowerLauncherInstaller.InstallerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="PowerLauncher Setup"
        Height="480" Width="600"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        ExtendsContentIntoTitleBar="True">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="PowerLauncher Setup" ShowMaximize="False"/>

        <!-- Page 1: Welcome -->
        <Grid x:Name="WelcomePage" Grid.Row="1" Margin="40">
            <StackPanel VerticalAlignment="Center">
                <ui:SymbolIcon Symbol="Rocket24" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,16"/>
                <TextBlock Text="PowerLauncher" FontSize="28" FontWeight="Bold" 
                           HorizontalAlignment="Center"
                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                <TextBlock Text="Version 1.0.0" FontSize="13" HorizontalAlignment="Center"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,4,0,24"/>
                <TextBlock Text="This will install PowerLauncher on your computer." 
                           FontSize="13" HorizontalAlignment="Center"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,8"/>

                <Grid Margin="0,16,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <ui:TextBox x:Name="InstallPathBox" IsReadOnly="True"
                                Text="{Binding InstallPath}"/>
                    <ui:Button Grid.Column="1" Content="Browse" Click="Browse_Click" Margin="8,0,0,0"/>
                </Grid>

                <CheckBox x:Name="DesktopShortcut" Content="Create desktop shortcut" 
                          IsChecked="True" Margin="0,16,0,0"/>
                <CheckBox x:Name="StartMenuShortcut" Content="Create Start Menu shortcut" 
                          IsChecked="True" Margin="0,4,0,0"/>

                <ui:Button Content="Install" Appearance="Primary" 
                           HorizontalAlignment="Stretch" Margin="0,24,0,0"
                           Padding="16,12" FontSize="14" FontWeight="SemiBold"
                           Click="Install_Click"/>
            </StackPanel>
        </Grid>

        <!-- Page 2: Progress -->
        <Grid x:Name="ProgressPage" Grid.Row="1" Margin="40" Visibility="Collapsed">
            <StackPanel VerticalAlignment="Center">
                <ui:SymbolIcon Symbol="ArrowDownload24" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,16"/>
                <TextBlock x:Name="ProgressTitle" Text="Installing..." FontSize="22" FontWeight="Bold"
                           HorizontalAlignment="Center"
                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                <TextBlock x:Name="ProgressStatus" Text="Downloading PowerLauncher..." 
                           FontSize="13" HorizontalAlignment="Center" Margin="0,8,0,24"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                <ProgressBar x:Name="ProgressBar" Height="8" IsIndeterminate="False" Value="0"/>
                <TextBlock x:Name="ProgressPercent" Text="0%" FontSize="12" 
                           HorizontalAlignment="Center" Margin="0,8,0,0"
                           Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
            </StackPanel>
        </Grid>

        <!-- Page 3: Done -->
        <Grid x:Name="DonePage" Grid.Row="1" Margin="40" Visibility="Collapsed">
            <StackPanel VerticalAlignment="Center">
                <ui:SymbolIcon Symbol="CheckmarkCircle24" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,16"/>
                <TextBlock Text="Installation Complete" FontSize="22" FontWeight="Bold"
                           HorizontalAlignment="Center"
                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                <TextBlock Text="PowerLauncher has been installed successfully." 
                           FontSize="13" HorizontalAlignment="Center" Margin="0,8,0,24"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                <CheckBox x:Name="LaunchAfter" Content="Launch PowerLauncher now" 
                          IsChecked="True" HorizontalAlignment="Center" Margin="0,0,0,16"/>
                <ui:Button Content="Finish" Appearance="Primary" 
                           HorizontalAlignment="Stretch" Padding="16,12"
                           FontSize="14" FontWeight="SemiBold"
                           Click="Finish_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</ui:FluentWindow>
