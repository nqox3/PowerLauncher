<ui:FluentWindow x:Class="PowerLauncherInstaller.InstallerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="PowerLauncher Setup" Height="500" Width="650"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        ExtendsContentIntoTitleBar="True">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <ui:TitleBar Grid.Row="0" Title="PowerLauncher Setup" ShowMaximize="False"/>
        <Border Grid.Row="1" Padding="20,10"
                Background="{DynamicResource ControlFillColorDefaultBrush}"
                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
            <StackPanel x:Name="StepsPanel" Orientation="Horizontal" HorizontalAlignment="Center"/>
        </Border>
        <Grid Grid.Row="2" Margin="32">
            <StackPanel x:Name="Page1" VerticalAlignment="Center" HorizontalAlignment="Center">
                <ui:SymbolIcon Symbol="Rocket24" FontSize="40" HorizontalAlignment="Center" Margin="0,0,0,12"/>
                <Label Content="Welcome to PowerLauncher Setup" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center"/>
                <Label Content="Version 1.0.0" FontSize="12" HorizontalAlignment="Center" Opacity="0.5" Margin="0,4,0,16"/>
                <Label Content="Click Next to continue." HorizontalAlignment="Center" Opacity="0.7"/>
            </StackPanel>
            <Grid x:Name="Page2" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Label Content="License Agreement" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <Border Grid.Row="1" CornerRadius="4" Padding="12" BorderThickness="1"
                        Background="{DynamicResource ControlFillColorDefaultBrush}"
                        BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <Label Content="MIT License. Copyright 2024 PowerLauncher Team. Permission granted. AS IS, NO WARRANTY." FontFamily="Consolas" FontSize="11" Opacity="0.7"/>
                    </ScrollViewer>
                </Border>
                <CheckBox x:Name="AcceptLicense" Grid.Row="2" Content="I accept the license agreement" Margin="0,10,0,0"/>
            </Grid>
            <StackPanel x:Name="Page3" Visibility="Collapsed">
                <Label Content="Installation Options" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,14"/>
                <Label Content="Install location:" FontSize="12" Opacity="0.6" Margin="0,0,0,4"/>
                <Grid Margin="0,0,0,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <ui:TextBox x:Name="InstallPathBox" IsReadOnly="True"/>
                    <ui:Button Grid.Column="1" Content="Browse" Click="Browse_Click" Margin="8,0,0,0"/>
                </Grid>
                <CheckBox x:Name="DesktopShortcut" Content="Create desktop shortcut" IsChecked="True" Margin="0,4"/>
                <CheckBox x:Name="StartMenuShortcut" Content="Create Start Menu shortcut" IsChecked="True" Margin="0,4"/>
                <CheckBox x:Name="LaunchOnStartup" Content="Run on Windows startup" Margin="0,4"/>
            </StackPanel>
            <StackPanel x:Name="Page4" Visibility="Collapsed" VerticalAlignment="Center">
                <ui:SymbolIcon Symbol="ArrowDownload24" FontSize="40" HorizontalAlignment="Center" Margin="0,0,0,12"/>
                <Label x:Name="ProgressTitle" Content="Installing..." FontSize="18" FontWeight="Bold" HorizontalAlignment="Center"/>
                <Label x:Name="ProgressStatus" Content="Preparing..." FontSize="12" HorizontalAlignment="Center" Opacity="0.6" Margin="0,6,0,18"/>
                <ProgressBar x:Name="ProgressBar" Height="8" Value="0" Margin="0,0,0,6"/>
                <Label x:Name="ProgressPercent" Content="0%" FontSize="11" HorizontalAlignment="Center" Opacity="0.5"/>
            </StackPanel>
            <StackPanel x:Name="Page5" Visibility="Collapsed" VerticalAlignment="Center" HorizontalAlignment="Center">
                <ui:SymbolIcon Symbol="CheckmarkCircle24" FontSize="40" HorizontalAlignment="Center" Margin="0,0,0,12"/>
                <Label Content="Installation Complete" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center"/>
                <Label Content="PowerLauncher is ready to use." FontSize="13" HorizontalAlignment="Center" Opacity="0.6" Margin="0,6,0,18"/>
                <CheckBox x:Name="LaunchAfter" Content="Launch PowerLauncher now" IsChecked="True" HorizontalAlignment="Center"/>
            </StackPanel>
        </Grid>
        <Border Grid.Row="3" Padding="20,10"
                Background="{DynamicResource ControlFillColorDefaultBrush}"
                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <ui:Button x:Name="CancelBtn" Content="Cancel" Click="Cancel_Click" Padding="14,7"/>
                <ui:Button x:Name="BackBtn" Grid.Column="2" Content="Back" Click="Back_Click" Padding="14,7" Margin="0,0,8,0" Visibility="Collapsed"/>
                <ui:Button x:Name="NextBtn" Grid.Column="3" Content="Next" Click="Next_Click" Appearance="Primary" Padding="14,7"/>
            </Grid>
        </Border>
    </Grid>
</ui:FluentWindow>
