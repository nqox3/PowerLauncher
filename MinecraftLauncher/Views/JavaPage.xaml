<Page x:Class="MinecraftLauncher.Views.JavaPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Title="Java">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="☕ Java Runtime" 
                       FontSize="28" FontWeight="Bold"
                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
            <TextBlock Text="Manage Java installation for Minecraft" 
                       FontSize="14" Opacity="0.7"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
        </StackPanel>

        <StackPanel Grid.Row="1">
            <ui:CardControl Margin="0,0,0,12">
                <ui:CardControl.Header>
                    <StackPanel>
                        <TextBlock Text="Status" FontWeight="SemiBold" FontSize="16"/>
                        <TextBlock Text="Current Java runtime information" Opacity="0.6" FontSize="12"/>
                    </StackPanel>
                </ui:CardControl.Header>
                <StackPanel>
                    <TextBlock x:Name="JavaVersionText" Text="Checking..." FontSize="14" Margin="0,4"/>
                    <TextBlock x:Name="JavaPathText" Text="" FontSize="12" Opacity="0.6" Margin="0,4"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </ui:CardControl>

            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                <ui:Button x:Name="InstallBtn" Content="Install/Reinstall Java 21" 
                           Icon="{ui:SymbolIcon ArrowDownload24}"
                           Appearance="Primary" Click="Install_Click" Margin="0,0,8,0"/>
                <ui:Button Content="Refresh" Icon="{ui:SymbolIcon ArrowSync24}" 
                           Click="Refresh_Click"/>
            </StackPanel>

            <ProgressBar x:Name="ProgressBar" Margin="0,16,0,0" Visibility="Collapsed"/>
            <TextBlock x:Name="StatusText" Text="" Margin="0,8,0,0" FontSize="12"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
        </StackPanel>
    </Grid>
</Page>
