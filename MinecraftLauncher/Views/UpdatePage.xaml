<Page x:Class="MinecraftLauncher.Views.UpdatePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Title="Updates">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="Updates" FontSize="28" FontWeight="Bold"
                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
            <TextBlock Text="Check for new versions of PowerLauncher" 
                       FontSize="14" Opacity="0.7"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
        </StackPanel>

        <StackPanel Grid.Row="1">
            <ui:CardControl Margin="0,0,0,12">
                <ui:CardControl.Header>
                    <StackPanel>
                        <TextBlock Text="Current Version" FontWeight="SemiBold" FontSize="16"/>
                    </StackPanel>
                </ui:CardControl.Header>
                <TextBlock x:Name="CurrentVersionText" Text="v1.0.0" FontSize="14"/>
            </ui:CardControl>

            <ui:CardControl Margin="0,0,0,12">
                <ui:CardControl.Header>
                    <StackPanel>
                        <TextBlock Text="Update Status" FontWeight="SemiBold" FontSize="16"/>
                    </StackPanel>
                </ui:CardControl.Header>
                <StackPanel>
                    <TextBlock x:Name="UpdateStatusText" Text="Click Check to look for updates" FontSize="13"/>
                    <TextBlock x:Name="ReleaseNotesText" Text="" FontSize="11" Opacity="0.7"
                               TextWrapping="Wrap" Margin="0,8,0,0"/>
                </StackPanel>
            </ui:CardControl>

            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                <ui:Button x:Name="CheckBtn" Content="Check for Updates" 
                           Icon="{ui:SymbolIcon ArrowSync24}"
                           Appearance="Primary" Click="Check_Click" Margin="0,0,8,0"/>
                <ui:Button x:Name="InstallBtn" Content="Download and Install" 
                           Icon="{ui:SymbolIcon ArrowDownload24}"
                           Appearance="Success" Click="Install_Click" 
                           Visibility="Collapsed"/>
            </StackPanel>

            <ProgressBar x:Name="ProgressBar" Margin="0,16,0,0" Visibility="Collapsed"/>
            <TextBlock x:Name="ProgressText" Text="" Margin="0,4,0,0" FontSize="11"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
        </StackPanel>
    </Grid>
</Page>
