<Page x:Class="MinecraftLauncher.Views.AboutPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Title="About">

    <StackPanel Margin="24" VerticalAlignment="Center" HorizontalAlignment="Center">
        <ui:SymbolIcon Symbol="Rocket24" FontSize="64" HorizontalAlignment="Center" Margin="0,0,0,16"/>
        <TextBlock Text="Minecraft Launcher" FontSize="28" FontWeight="Bold" 
                   HorizontalAlignment="Center"
                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
        <TextBlock Text="Version 1.0.0" FontSize="14" Opacity="0.7" 
                   HorizontalAlignment="Center" Margin="0,4,0,16"
                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
        <TextBlock Text="A powerful Minecraft launcher built with WPF UI" 
                   FontSize="14" HorizontalAlignment="Center" Opacity="0.8"
                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
        <TextBlock Margin="0,24,0,0" HorizontalAlignment="Center" FontSize="12" Opacity="0.5"
                   Foreground="{DynamicResource TextFillColorTertiaryBrush}">
            <Run Text="Built with CmlLib.Core + WPF UI + .NET 8"/>
        </TextBlock>
    </StackPanel>
</Page>
