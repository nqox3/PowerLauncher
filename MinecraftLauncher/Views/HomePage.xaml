<Page x:Class="MinecraftLauncher.Views.HomePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:vm="clr-namespace:MinecraftLauncher.ViewModels"
      Title="Home">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,24">
            <TextBlock Text="⛏️ PowerLauncher" 
                       FontSize="32" FontWeight="Bold" 
                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
            <TextBlock Text="Select a version and launch your game" 
                       FontSize="14" Opacity="0.7"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
        </StackPanel>

        <!-- Main Content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left: Version & Account -->
            <StackPanel Grid.Column="0" Margin="0,0,12,0">
                <ui:CardControl Margin="0,0,0,12">
                    <ui:CardControl.Header>
                        <StackPanel>
                            <TextBlock Text="🎮 Game Version" FontWeight="SemiBold" FontSize="16"/>
                            <TextBlock Text="Choose which version to play" Opacity="0.6" FontSize="12"/>
                        </StackPanel>
                    </ui:CardControl.Header>
                    <StackPanel>
                        <ComboBox ItemsSource="{Binding Versions}" 
                                  SelectedItem="{Binding SelectedVersion}"
                                  Margin="0,0,0,8" MinWidth="200"/>
                        <ui:Button Content="Refresh Versions" 
                                   Icon="{ui:SymbolIcon ArrowSync24}"
                                   Command="{Binding LoadVersionsCommand}"
                                   Appearance="Secondary"/>
                    </StackPanel>
                </ui:CardControl>

                <ui:CardControl>
                    <ui:CardControl.Header>
                        <StackPanel>
                            <TextBlock Text="👤 Account" FontWeight="SemiBold" FontSize="16"/>
                            <TextBlock Text="Manage player accounts" Opacity="0.6" FontSize="12"/>
                        </StackPanel>
                    </ui:CardControl.Header>
                    <StackPanel>
                        <ComboBox ItemsSource="{Binding Accounts}" 
                                  SelectedItem="{Binding SelectedAccount}"
                                  DisplayMemberPath="Username"
                                  Margin="0,0,0,8" MinWidth="200"/>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ui:TextBox PlaceholderText="Username" 
                                        Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                                        Margin="0,0,8,0"/>
                            <ui:Button Grid.Column="1" Content="➕" ToolTip="Add Account"
                                       Command="{Binding AddOfflineAccountCommand}"
                                       Appearance="Primary" Margin="0,0,4,0"/>
                            <ui:Button Grid.Column="2" Content="➖" ToolTip="Remove Account"
                                       Command="{Binding RemoveAccountCommand}"
                                       Appearance="Danger"/>
                        </Grid>
                    </StackPanel>
                </ui:CardControl>
            </StackPanel>

            <!-- Right: Quick Info & Player -->
            <StackPanel Grid.Column="1" Margin="12,0,0,0">
                <ui:CardControl Margin="0,0,0,12">
                    <ui:CardControl.Header>
                        <TextBlock Text="📊 Quick Info" FontWeight="SemiBold" FontSize="16"/>
                    </ui:CardControl.Header>
                    <StackPanel>
                        <TextBlock Margin="0,4">
                            <Run Text="Version: " FontWeight="SemiBold"/>
                            <Run Text="{Binding SelectedVersion, Mode=OneWay}"/>
                        </TextBlock>
                        <TextBlock Margin="0,4">
                            <Run Text="Player: " FontWeight="SemiBold"/>
                            <Run Text="{Binding Username, Mode=OneWay}"/>
                        </TextBlock>
                        <TextBlock Margin="0,4">
                            <Run Text="RAM: " FontWeight="SemiBold"/>
                            <Run Text="{Binding Settings.MaxRamMb, Mode=OneWay}"/>
                            <Run Text=" MB"/>
                        </TextBlock>
                        <TextBlock Margin="0,4">
                            <Run Text="Mods: " FontWeight="SemiBold"/>
                            <Run Text="{Binding ModCount, Mode=OneWay}"/>
                        </TextBlock>
                    </StackPanel>
                </ui:CardControl>

                <!-- Player Head Preview -->
                <ui:CardControl>
                    <ui:CardControl.Header>
                        <TextBlock Text="🧑 Player" FontWeight="SemiBold" FontSize="16"/>
                    </ui:CardControl.Header>
                    <StackPanel HorizontalAlignment="Center">
                        <Image x:Name="PlayerHeadImage" Width="64" Height="64"
                               RenderOptions.BitmapScalingMode="NearestNeighbor"
                               Margin="0,4"/>
                        <TextBlock Text="{Binding Username, Mode=OneWay}" 
                                   HorizontalAlignment="Center" FontSize="12" Margin="0,4,0,0"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>
                </ui:CardControl>
            </StackPanel>
        </Grid>

        <!-- Launch Button -->
        <StackPanel Grid.Row="2" Margin="0,24,0,0">
            <ui:Button Content="🚀 LAUNCH MINECRAFT" 
                       Command="{Binding LaunchGameCommand}"
                       IsEnabled="{Binding IsLaunching, Converter={StaticResource InverseBoolConverter}}"
                       HorizontalAlignment="Stretch"
                       FontSize="18" FontWeight="Bold"
                       Padding="24,16"
                       Appearance="Primary"/>
            <ProgressBar Value="{Binding Progress}" 
                         Margin="0,8,0,0"
                         Visibility="{Binding IsLaunching, Converter={StaticResource BoolToVisConverter}}"/>
        </StackPanel>
    </Grid>
</Page>
