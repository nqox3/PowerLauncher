<Page x:Class="MinecraftLauncher.Views.MarketPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Title="Mod Market">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="Mod Market" 
                       FontSize="28" FontWeight="Bold"
                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
            <TextBlock Text="Browse and install mods from Modrinth" 
                       FontSize="14" Opacity="0.7"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
        </StackPanel>

        <!-- Search & Filters -->
        <Grid Grid.Row="1" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <ui:TextBox x:Name="SearchBox" PlaceholderText="Search mods..."
                        KeyDown="SearchBox_KeyDown" Margin="0,0,8,0"/>

            <ComboBox x:Name="LoaderFilter" Grid.Column="1" Width="120" Margin="0,0,8,0"
                      SelectedIndex="0">
                <ComboBoxItem Content="All Loaders"/>
                <ComboBoxItem Content="Fabric"/>
                <ComboBoxItem Content="Forge"/>
                <ComboBoxItem Content="Quilt"/>
                <ComboBoxItem Content="NeoForge"/>
            </ComboBox>

            <ComboBox x:Name="SortBy" Grid.Column="2" Width="130" Margin="0,0,8,0"
                      SelectedIndex="0">
                <ComboBoxItem Content="Relevance"/>
                <ComboBoxItem Content="Downloads"/>
                <ComboBoxItem Content="Updated"/>
                <ComboBoxItem Content="Newest"/>
            </ComboBox>

            <ui:Button Grid.Column="3" Content="Search" 
                       Icon="{ui:SymbolIcon Search24}"
                       Appearance="Primary" Click="Search_Click"/>
        </Grid>

        <!-- Results -->
        <ListView Grid.Row="2" x:Name="ModsList" 
                  SelectionMode="Single"
                  ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border Padding="8" Margin="0,2" CornerRadius="6"
                            Background="{DynamicResource ControlFillColorDefaultBrush}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="48"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- Mod Icon -->
                            <Border Grid.Column="0" Width="40" Height="40" CornerRadius="6"
                                    Background="{DynamicResource ControlFillColorSecondaryBrush}">
                                <Image Source="{Binding IconUrl}" Stretch="UniformToFill"
                                       RenderOptions.BitmapScalingMode="HighQuality"/>
                            </Border>

                            <!-- Info -->
                            <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="14"/>
                                    <Border Margin="8,0,0,0" Padding="4,1" CornerRadius="3"
                                            Background="#2d5a27" Visibility="{Binding Loader, Converter={StaticResource LoaderToVisibility}}">
                                        <TextBlock Text="{Binding Loader}" FontSize="10" Foreground="White"/>
                                    </Border>
                                </StackPanel>
                                <TextBlock Text="{Binding Description}" FontSize="11" Opacity="0.7"
                                           TextTrimming="CharacterEllipsis" MaxWidth="400"/>
                                <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                    <TextBlock Text="{Binding Author}" FontSize="10" Opacity="0.5"/>
                                    <TextBlock Text=" • " FontSize="10" Opacity="0.5"/>
                                    <TextBlock Text="{Binding Downloads, StringFormat='{}{0:N0} downloads'}" 
                                               FontSize="10" Opacity="0.5"/>
                                </StackPanel>
                            </StackPanel>

                            <!-- Source Badge -->
                            <Border Grid.Column="2" Padding="6,2" CornerRadius="3" 
                                    VerticalAlignment="Center" Margin="8,0"
                                    Background="#1bd96a">
                                <TextBlock Text="{Binding Source}" FontSize="10" Foreground="Black" FontWeight="SemiBold"/>
                            </Border>

                            <!-- Install Button -->
                            <ui:Button Grid.Column="3" Content="Install" 
                                       Appearance="Primary" Padding="12,6"
                                       Click="Install_Click" Tag="{Binding}"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- Status -->
        <Grid Grid.Row="3" Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="MarketStatus" Text="Search for mods to get started" 
                       FontSize="12" VerticalAlignment="Center"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
            <ProgressBar x:Name="DownloadProgress" Grid.Column="1" Width="200" 
                         Visibility="Collapsed"/>
        </Grid>
    </Grid>
</Page>
