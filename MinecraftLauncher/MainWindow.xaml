<ui:FluentWindow x:Class="MinecraftLauncher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:vm="clr-namespace:MinecraftLauncher.ViewModels"
        xmlns:views="clr-namespace:MinecraftLauncher.Views"
        Title="PowerLauncher" 
        Height="720" Width="1100"
        MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        ExtendsContentIntoTitleBar="True">

    <ui:FluentWindow.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisConverter"/>
    </ui:FluentWindow.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="PowerLauncher" ShowMaximize="True" ShowMinimize="True"/>

        <ui:NavigationView Grid.Row="1" x:Name="NavigationView" 
                           PaneDisplayMode="Left"
                           IsBackButtonVisible="Collapsed">
            <ui:NavigationView.MenuItems>
                <ui:NavigationViewItem Content="Home" 
                                       Icon="{ui:SymbolIcon Home24}" 
                                       TargetPageType="{x:Type views:HomePage}"/>
                <ui:NavigationViewItem Content="Mod Market" 
                                       Icon="{ui:SymbolIcon Cart24}" 
                                       TargetPageType="{x:Type views:MarketPage}"/>
                <ui:NavigationViewItem Content="My Mods" 
                                       Icon="{ui:SymbolIcon PuzzlePiece24}" 
                                       TargetPageType="{x:Type views:ModsPage}"/>
                <ui:NavigationViewItem Content="Skins" 
                                       Icon="{ui:SymbolIcon Person24}" 
                                       TargetPageType="{x:Type views:SkinsPage}"/>
                <ui:NavigationViewItem Content="Java" 
                                       Icon="{ui:SymbolIcon Code24}" 
                                       TargetPageType="{x:Type views:JavaPage}"/>
                <ui:NavigationViewItem Content="Console" 
                                       Icon="{ui:SymbolIcon WindowConsole20}" 
                                       TargetPageType="{x:Type views:ConsolePage}"/>
            </ui:NavigationView.MenuItems>
            <ui:NavigationView.FooterMenuItems>
                <ui:NavigationViewItem Content="Settings" 
                                       Icon="{ui:SymbolIcon Settings24}" 
                                       TargetPageType="{x:Type views:SettingsPage}"/>
                <ui:NavigationViewItem Content="About" 
                                       Icon="{ui:SymbolIcon Info24}" 
                                       TargetPageType="{x:Type views:AboutPage}"/>
            </ui:NavigationView.FooterMenuItems>
        </ui:NavigationView>

        <Border Grid.Row="2" 
                Background="{DynamicResource ControlFillColorDefaultBrush}" 
                Padding="12,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="{Binding StatusText}" 
                           VerticalAlignment="Center" FontSize="12"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                <TextBlock Grid.Column="1" Text="PowerLauncher v1.0.0" 
                           VerticalAlignment="Center" FontSize="11" Opacity="0.5"
                           Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
            </Grid>
        </Border>
    </Grid>
</ui:FluentWindow>
